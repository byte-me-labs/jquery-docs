<%
/**
 * Cheatsheet — multi-column API reference with version-range filter.
 * Ranges are built from actual semver breakpoints (added/deprecated/removed).
 */
// Parse any jQuery version string to a numeric value for comparison.
// Handles: "1.0", "1.10.3", "1.10-and-2.0", "1.12-and-2.2", "1" (bare major)
function parseVer(v) {
  if (!v) return 0;
  // Normalize combined markers: "1.10-and-2.0" → "1.10"
  var clean = String(v).replace(/-and-.*$/, '');
  // Split on dots only (hyphens already stripped)
  var parts = clean.split('.');
  var maj = parseInt(parts[0], 10) || 0;
  var min = parseInt(parts[1], 10) || 0;
  var patch = parseInt(parts[2], 10) || 0;
  return maj * 1000000 + min * 1000 + patch;
}
function fmtVer(v) {
  var clean = String(v).replace(/-and-.*$/, '');
  var parts = clean.split('.');
  return parts[0] + '.' + (parts[1] || '0');
}
// Build version string from parsed numeric value
function unparseVer(n) {
  var maj = Math.floor(n / 1000000);
  var min = Math.floor((n % 1000000) / 1000);
  return maj + '.' + min;
}

// Collect breakpoints only from deprecation & removal events — these are the
// versions where the API surface actually changed in a user-visible way.
var breakpoints = {};
for (var i = 0; i < entries.length; i++) {
  var ev = entries[i].versions;
  if (ev.deprecated) breakpoints[ev.deprecated] = true;
  if (ev.removed) breakpoints[ev.removed] = true;
}

// Sort breakpoints by semver, normalize to major.minor, deduplicate
var bpList = Object.keys(breakpoints).sort(function(a, b) { return parseVer(a) - parseVer(b); });
var majors = {}; // deduplicate to major.minor
for (var bi = 0; bi < bpList.length; bi++) {
  var normalized = fmtVer(bpList[bi]);
  majors[normalized] = true;
}
var verList = Object.keys(majors).sort(function(a, b) { return parseVer(a) - parseVer(b); });

// Build ranges: half-open intervals [from, to)
// Show labels as "X.Y.0 – A.B.x" for clarity
function prevMinor(v) {
  var parts = String(v).split('.');
  var maj = parseInt(parts[0], 10);
  var min = parseInt(parts[1] || 0, 10);
  if (min === 0) return (maj - 1) + '.x';
  return maj + '.' + (min - 1) + '.x';
}
var ranges = [];
for (var ri = 0; ri < verList.length; ri++) {
  var from = verList[ri];
  var to = (ri + 1 < verList.length) ? verList[ri + 1] : '';
  var label;
  if (!to) {
    label = 'jQuery ≥ ' + fmtVer(from) + '.0';
  } else {
    label = 'jQuery ' + fmtVer(from) + '.0 – ' + prevMinor(to);
  }
  ranges.push({ from: from, to: to, label: label });
}

var entryMap = {};
for (var i = 0; i < entries.length; i++) {
  entryMap[entries[i].id] = entries[i];
}

var catsList = Array.isArray(categories) ? categories : (categories.children || []);
var displayCats = catsList.filter(function(c) {
  return c.slug !== 'version' && c.slug !== 'deprecated' && c.slug !== 'removed' && c.slug !== 'uncategorized';
});

// Tooltip HTML builder
function buildTooltip(entry) {
  var html = '<div class="tt-desc">' + (entry.desc || '') + '</div>';
  // Signatures
  if (entry.signatures && entry.signatures.length > 0) {
    html += '<div class="tt-sig">';
    for (var si = 0; si < entry.signatures.length; si++) {
      var sig = entry.signatures[si];
      var args = sig.arguments ? sig.arguments.map(function(a) { return a.name; }).join(', ') : '';
      html += '<code>' + entry.title + '(' + args + ')</code>';
      if (entry.return) html += ' → <em>' + entry.return + '</em>';
      if (si < entry.signatures.length - 1) html += '<br>';
    }
    html += '</div>';
  }
  // Version status
  html += '<div class="tt-ver">';
  if (entry.versions.added) html += 'Added ' + entry.versions.added;
  if (entry.versions.deprecated) html += ' · Deprecated ' + entry.versions.deprecated;
  if (entry.versions.removed) html += ' · Removed ' + entry.versions.removed;
  html += '</div>';
  return html;
}

// Sort by entry count descending
displayCats.sort(function(a, b) {
  function total(n) { var c = (categoryEntries[n.slug]||[]).length; if(n.children)n.children.forEach(function(ch){c+=total(ch)}); return c; }
  return total(b) - total(a);
});

function collectEntries(node, entriesMap) {
  var seen = {};
  var result = [];
  function add(ids) {
    for (var k = 0; k < ids.length; k++) {
      if (!seen[ids[k]]) { seen[ids[k]] = true; result.push(ids[k]); }
    }
  }
  add(entriesMap[node.slug] || []);
  if (node.children) {
    for (var j = 0; j < node.children.length; j++) {
      add(collectEntries(node.children[j], entriesMap));
    }
  }
  return result;
}

function absStatus(entry) {
  if (entry.versions.removed) return 'removed';
  if (entry.versions.deprecated) return 'deprecated';
  return 'active';
}

// Version label for "All Versions" — placed before API name, colored by status
// Green: active, Yellow: deprecated, Red: removed
// Version label — latest-version perspective:
// 1.0-based: removed→Z.W-(red) | deprecated→Z.W-(yellow) | active→blank
// non-1.0:   removed→X.Y+ Z.W-(red) | deprecated→X.Y+ Z.W-(yellow) | active→X.Y+(green)
function verLabel(entry) {
  var added = fmtVer(entry.versions.added || '1.0');
  var from1 = (added === '1.0');
  if (entry.versions.removed) {
    var r = fmtVer(entry.versions.removed);
    return '<span class="ver-label ver-removed">' + (from1 ? r + '-' : added + '+ ' + r + '-') + '</span>';
  }
  if (entry.versions.deprecated) {
    var d = fmtVer(entry.versions.deprecated);
    return '<span class="ver-label ver-deprecated">' + (from1 ? d + '-' : added + '+ ' + d + '-') + '</span>';
  }
  if (from1) return '';
  return '<span class="ver-label ver-active">' + added + '+</span>';
}
%>
<div class="cheatsheet-page">
<header class="cheatsheet-header">
  <h1>jQuery API Cheatsheet</h1>
  <div class="cheatsheet-controls">
    <input type="text" id="cheatsheet-search" placeholder="Search APIs..." autofocus>
    <span id="search-count"></span>
    <div class="cheatsheet-ver-filter">
      <select id="cheatsheet-version">
        <option value="" data-from="" data-to="">All Versions</option>
        <% for (var ri = 0; ri < ranges.length; ri++) { %>
          <option value="<%= ranges[ri].from %>" data-from="<%= ranges[ri].from %>" data-to="<%= ranges[ri].to %>"><%= ranges[ri].label %></option>
        <% } %>
      </select>
    </div>
  </div>
  <div class="cheatsheet-legend" id="cheatsheet-legend">
    <span class="ver-active">Active</span>
    <span class="ver-deprecated">Deprecated</span>
    <span class="ver-removed">Removed</span>
  </div>
</header>

<div id="cheatsheet-grid" class="cheatsheet-grid">
  <% for (var i = 0; i < displayCats.length; i++) {
    var cat = displayCats[i];
    var allCatEntries = collectEntries(cat, categoryEntries);
  %>
    <div class="cheatsheet-category" data-category="<%= cat.slug %>">
      <h2><%= cat.name %></h2>
      <% if (cat.children && cat.children.length > 0) { %>
        <% for (var si = 0; si < cat.children.length; si++) {
          var sub = cat.children[si];
          var subEntries = collectEntries(sub, categoryEntries);
          if (subEntries.length === 0) continue;
        %>
        <div class="cheatsheet-subcat" data-subcategory="<%= sub.slug %>">
          <h3><%= sub.name %></h3>
          <ul>
            <% for (var ei = 0; ei < subEntries.length; ei++) {
              var e = entryMap[subEntries[ei]];
              if (!e || !e.title) continue;
              var sAll = absStatus(e);
            %>
            <li class="cheatsheet-entry" data-id="<%= e.id %>" data-name="<%= e.title.toLowerCase() %>" data-desc="<%= e.desc.toLowerCase() %>" data-added="<%= e.versions.added || '1.0' %>" data-removed="<%= e.versions.removed || '' %>" data-deprecated="<%= e.versions.deprecated || '' %>" data-cats="<%= e.categories.join(' ') %>" data-tooltip="<%- he.encode(buildTooltip(e), {useNamedReferences: true}) %>">
              <a href="api/<%= e.id %>.html">
                <span class="cheatsheet-ver-tag"><%- verLabel(e) %></span>
                <span class="cheatsheet-name"><%= e.title %></span>
              </a>
            </li>
            <% } %>
          </ul>
        </div>
        <% } %>
      <% } %>
      <% if (allCatEntries.length > 0 && (!cat.children || cat.children.length === 0)) { %>
        <ul>
          <% for (var ei = 0; ei < allCatEntries.length; ei++) {
            var e = entryMap[allCatEntries[ei]];
            if (!e || !e.title) continue;
            var sAll = absStatus(e);
          %>
          <li class="cheatsheet-entry" data-id="<%= e.id %>" data-name="<%= e.title.toLowerCase() %>" data-desc="<%= e.desc.toLowerCase() %>" data-added="<%= e.versions.added || '1.0' %>" data-removed="<%= e.versions.removed || '' %>" data-deprecated="<%= e.versions.deprecated || '' %>" data-cats="<%= e.categories.join(' ') %>" data-tooltip="<%- he.encode(buildTooltip(e), {useNamedReferences: true}) %>">
            <a href="api/<%= e.id %>.html">
              <span class="cheatsheet-ver-tag"><%- verLabel(e) %></span>
              <span class="cheatsheet-name"><%= e.title %></span>
            </a>
          </li>
          <% } %>
        </ul>
      <% } %>
    </div>
  <% } %>
</div>

<footer class="cheatsheet-footer">
  <p><%= entries.length %> APIs &bull; jQuery 1.0–4.x &bull; Generated from <a href="https://api.jquery.com">api.jquery.com</a></p>
</footer>
</div>

<script>
(function() {
  var searchInput = document.getElementById('cheatsheet-search');
  var countEl = document.getElementById('search-count');
  var verSelect = document.getElementById('cheatsheet-version');
  var sidebarVer = document.getElementById('nav-version');
  var entries = document.querySelectorAll('.cheatsheet-entry');
  var categories = document.querySelectorAll('.cheatsheet-category');
  var subcats = document.querySelectorAll('.cheatsheet-subcat');

  // Sync both version selects (cheatsheet header + sidebar)
  function syncVersion(source) {
    var val = source.value;
    if (verSelect && source !== verSelect) verSelect.value = val;
    if (sidebarVer && source !== sidebarVer) sidebarVer.value = val;
  }
  if (verSelect) verSelect.addEventListener('change', function() { syncVersion(this); filterAll(); });
  if (sidebarVer) sidebarVer.addEventListener('change', function() { syncVersion(this); filterAll(); });

  function getVersionSelect() {
    // Prefer the visible one
    if (verSelect && verSelect.offsetParent !== null) return verSelect;
    if (sidebarVer && sidebarVer.offsetParent !== null) return sidebarVer;
    return verSelect || sidebarVer;
  }

  function parseVer(v) {
    if (!v) return 0;
    var clean = String(v).replace(/-and-.*$/, '');
    var parts = clean.split('.');
    var maj = parseInt(parts[0], 10) || 0;
    var min = parseInt(parts[1], 10) || 0;
    var patch = parseInt(parts[2], 10) || 0;
    return maj * 1000000 + min * 1000 + patch;
  }

  function versionMatch(el, fromVal, toVal) {
    if (!fromVal) return true;
    var added = parseVer(el.getAttribute('data-added') || '1.0');
    var removedStr = el.getAttribute('data-removed');
    var removed = removedStr ? parseVer(removedStr) : 999999999;
    var fv = parseVer(fromVal);
    var tv = toVal ? parseVer(toVal) : 999999999;
    if (added >= tv) return false;
    if (removed <= fv) return false;
    return true;
  }

  function rangeStatus(el, fromVal, toVal) {
    if (!fromVal) {
      return el.getAttribute('data-removed') ? 'removed'
           : el.getAttribute('data-deprecated') ? 'deprecated'
           : 'active';
    }
    var removedStr = el.getAttribute('data-removed');
    var deprecatedStr = el.getAttribute('data-deprecated');
    var fv = parseVer(fromVal);
    var tv = toVal ? parseVer(toVal) : 999999999;
    if (removedStr) {
      var rv = parseVer(removedStr);
      if (rv > fv && rv < tv) return 'removed';
    }
    if (deprecatedStr && parseVer(deprecatedStr) <= fv) return 'deprecated';
    return 'active';
  }

  // Save original version labels
  for (var i = 0; i < entries.length; i++) {
    var tag = entries[i].querySelector('.cheatsheet-ver-tag');
    if (tag && !entries[i].getAttribute('data-ver-label')) {
      entries[i].setAttribute('data-ver-label', tag.innerHTML);
    }
  }

  function updateVerTag(el, fromVal, toVal) {
    var tag = el.querySelector('.cheatsheet-ver-tag');
    var nameEl = el.querySelector('.cheatsheet-name');
    if (!tag) return;
    if (fromVal) {
      var inRange = versionMatch(el, fromVal, toVal);
      var status = inRange ? rangeStatus(el, fromVal, toVal) : 'na';
      tag.innerHTML = inRange ? (status.charAt(0).toUpperCase() + status.slice(1)) : '&ndash;';
      tag.className = 'cheatsheet-ver-tag ver-status-' + (inRange ? status : 'na');
      if (nameEl) nameEl.style.opacity = inRange ? '' : '0.4';
    } else {
      tag.innerHTML = el.getAttribute('data-ver-label') || '';
      tag.className = 'cheatsheet-ver-tag';
      if (nameEl) nameEl.style.opacity = '';
    }
  }

  function updateCount(visible) {
    countEl.textContent = visible + ' of ' + entries.length + ' APIs';
  }

  function filterAll() {
    var q = searchInput.value.toLowerCase().trim();
    var vs = getVersionSelect();
    var opt = vs ? vs.selectedOptions[0] : null;
    var fv = opt ? opt.getAttribute('data-from') : '';
    var tv = opt ? opt.getAttribute('data-to') : '';
    var visible = 0;

    for (var j = 0; j < entries.length; j++) {
      var el = entries[j];
      var haystack = (el.getAttribute('data-name') || '') + ' '
                   + (el.getAttribute('data-desc') || '') + ' '
                   + (el.getAttribute('data-cats') || '');
      el.style.display = (!q || haystack.toLowerCase().indexOf(q) !== -1) ? '' : 'none';
      if (el.style.display !== 'none') {
        updateVerTag(el, fv, tv);
        visible++;
      }
    }

    for (var k = 0; k < subcats.length; k++) {
      var sn = subcats[k].querySelectorAll('.cheatsheet-entry:not([style*="display: none"])').length;
      subcats[k].style.display = sn === 0 ? 'none' : '';
    }
    for (var m = 0; m < categories.length; m++) {
      var cn = categories[m].querySelectorAll('.cheatsheet-entry:not([style*="display: none"])').length;
      categories[m].style.display = cn === 0 ? 'none' : '';
    }
    updateCount(visible);
  }

  filterAll();
  searchInput.addEventListener('input', filterAll);

  // Hover tooltip
  var tip = document.createElement('div');
  tip.className = 'cheatsheet-tooltip';
  tip.style.display = 'none';
  document.body.appendChild(tip);

  var tipEnt = null;
  for (var i = 0; i < entries.length; i++) {
    var el = entries[i];
    el.addEventListener('mouseenter', function() {
      tipEnt = this;
      tip.innerHTML = this.getAttribute('data-tooltip') || '';
      tip.style.display = '';
    });
    el.addEventListener('mouseleave', function() {
      tip.style.display = 'none';
      tipEnt = null;
    });
    el.addEventListener('mousemove', function(e) {
      if (tipEnt !== this) return;
      var x = (e || window.event).clientX + 12;
      var y = (e || window.event).clientY - 10;
      // Keep tooltip in viewport
      var tw = tip.offsetWidth || 300;
      var th = tip.offsetHeight || 80;
      if (x + tw > window.innerWidth) x = window.innerWidth - tw - 10;
      if (y + th > window.innerHeight) y = window.innerHeight - th - 10;
      tip.style.left = x + 'px';
      tip.style.top = y + 'px';
    });
  }
})();
</script>
