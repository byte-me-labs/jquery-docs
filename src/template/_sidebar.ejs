<%
/**
 * Navigation sidebar with version filter.
 * Expects: { categories, categoryEntries, entries, currentId, linkPrefix }
 */

function _(key) { return (typeof ui !== 'undefined' && ui && ui[key]) ? ui[key] : key; }

function parseVer(v) {
  if (!v) return 0;
  var clean = String(v).replace(/-and-.*$/, '');
  var parts = clean.split('.');
  var maj = parseInt(parts[0], 10) || 0;
  var min = parseInt(parts[1], 10) || 0;
  return maj * 1000000 + min * 1000 + (parseInt(parts[2], 10) || 0);
}

function renderTree(cat, entriesMap, allEntries, currentId, depth, seen) {
  var slug = cat.slug;
  var catEntries = entriesMap[slug] || [];
  var hasChildren = (cat.children && cat.children.length > 0);
  var hasEntries = catEntries.length > 0;
  var html = '';

  if (depth === 0) {
    html += '<div class="nav-category">';
    html += '<h3 class="nav-cat-title" data-slug="' + slug + '">' + cat.name + '</h3>';
    html += '<ul class="nav-cat-list" id="nav-' + slug + '">';
  } else if (hasChildren || hasEntries) {
    html += '<li class="nav-subcat">';
    html += '<h4 class="nav-subcat-title">' + cat.name + '</h4>';
    html += '<ul>';
  }

  function navVerLabel(entry) {
    var added = entry.versions.added || '1.0';
    function f(v) { var c=String(v).replace(/-and-.*$/,''); var p=c.split('.'); return p[0]+'.'+(p[1]||'0'); }
    var from1 = (String(added).indexOf('1.0') === 0);
    if (entry.versions.removed) {
      var r = f(entry.versions.removed);
      return '<span class="nav-ver nav-ver-removed">' + (from1 ? r + '-' : added + '+ ' + r + '-') + '</span>';
    }
    if (entry.versions.deprecated) {
      var d = f(entry.versions.deprecated);
      return '<span class="nav-ver nav-ver-deprecated">' + (from1 ? d + '-' : added + '+ ' + d + '-') + '</span>';
    }
    if (from1) return '';
    return '<span class="nav-ver nav-ver-active">' + added + '+</span>';
  }

  // Render children (sub-categories) before direct entries
  if (cat.children) {
    for (var j = 0; j < cat.children.length; j++) {
      html += renderTree(cat.children[j], entriesMap, allEntries, currentId, depth + 1, seen);
    }
  }

  for (var i = 0; i < catEntries.length; i++) {
    var entryId = catEntries[i];
    if (seen[entryId]) continue;
    seen[entryId] = true;
    var entry = allEntries.filter(function(e) { return e.id === entryId; })[0];
    if (!entry || !entry.title) continue;
    var isActive = (currentId === entryId);
    var cls = isActive ? 'nav-link active' : 'nav-link';
    var statusCls = '';
    if (entry.versions.removed) statusCls = ' status-removed';
    else if (entry.versions.deprecated) statusCls = ' status-deprecated';
    html += '<li><a class="' + cls + statusCls + '" href="' + (linkPrefix||'') + 'api/' + entryId + '.html"'
      + ' data-added="' + (entry.versions.added || '1.0') + '"'
      + (entry.versions.removed ? ' data-removed="' + entry.versions.removed + '"' : '')
      + (entry.versions.deprecated ? ' data-deprecated="' + entry.versions.deprecated + '"' : '')
      + '>' + entry.title + ' ' + navVerLabel(entry) + '</a></li>';
  }

  if (depth === 0) {
    html += '</ul></div>';
  } else if (hasChildren || hasEntries) {
    html += '</ul></li>';
  }

  return html;
}

var catsList = Array.isArray(categories) ? categories : (categories.children || []);
var displayCats = catsList.filter(function(c) {
  return c.slug !== 'version' && c.slug !== 'deprecated' && c.slug !== 'removed' && c.slug !== 'uncategorized';
});

// Sort by entry count descending — matches cheatsheet order
function sidebarTotal(node) {
  var n = (categoryEntries[node.slug] || []).length;
  if (node.children) node.children.forEach(function(ch) { n += sidebarTotal(ch); });
  return n;
}
displayCats.sort(function(a, b) {
  return sidebarTotal(b) - sidebarTotal(a);
});

// Build version range options (same logic as cheatsheet)
var breakpoints = {};
breakpoints['1.0'] = true;
for (var i = 0; i < entries.length; i++) {
  var ev = entries[i].versions;
  if (ev.deprecated) breakpoints[ev.deprecated] = true;
  if (ev.removed) breakpoints[ev.removed] = true;
}
var bpList = Object.keys(breakpoints).sort(function(a, b) { return parseVer(a) - parseVer(b); });
var majors = {};
for (var bi = 0; bi < bpList.length; bi++) {
  var clean = String(bpList[bi]).replace(/-and-.*$/, '');
  var parts = clean.split('.');
  majors[parts[0] + '.' + (parts[1] || '0')] = true;
}
var verList = Object.keys(majors).sort(function(a, b) { return parseVer(a) - parseVer(b); });
function prevMinor(v) {
  var parts = String(v).split('.');
  var maj = parseInt(parts[0], 10);
  var min = parseInt(parts[1] || 0, 10);
  if (min === 0) return (maj - 1) + '.x';
  return maj + '.' + (min - 1) + '.x';
}

var sidebarHTML = '';
sidebarHTML += '<div class="nav-fixed-controls">';
sidebarHTML += '<div class="nav-lang"><select id="nav-lang"><option value="en">EN</option><option value="zh">中文</option></select></div>';
sidebarHTML += '<div class="nav-version">';
sidebarHTML += '<select id="nav-version">';
sidebarHTML += '<option value="" data-from="" data-to="">' + _('All Versions') + '</option>';
for (var ri = 0; ri < verList.length; ri++) {
  var from = verList[ri];
  var to = (ri + 1 < verList.length) ? verList[ri + 1] : '';
  var label = to ? (from + '.0 – ' + prevMinor(to)) : ('≥ ' + from + '.0');
  sidebarHTML += '<option value="' + from + '" data-from="' + from + '" data-to="' + to + '">' + label + '</option>';
}
sidebarHTML += '</select></div>';

sidebarHTML += '<div class="nav-search"><input type="text" id="nav-search" placeholder="' + _('Filter APIs...') + '"></div>';
sidebarHTML += '</div>'; // close nav-fixed-controls
sidebarHTML += '<div class="nav-categories">';

for (var i = 0; i < displayCats.length; i++) {
  sidebarHTML += renderTree(displayCats[i], categoryEntries, entries, currentId, 0, {});
}

sidebarHTML += '<div class="nav-category"><ul class="nav-cat-list">';
sidebarHTML += '<li><a class="nav-link nav-cheatsheet" href="' + (linkPrefix||'') + 'cheatsheet.html">' + _('Cheatsheet') + '</a></li>';
sidebarHTML += '</ul></div>'; // close nav-cat-list, nav-category
sidebarHTML += '<div class="nav-links">';
sidebarHTML += '<a href="https://github.com/byte-me-labs/jquery-docs" target="_blank">GitHub</a>';
sidebarHTML += '<a href="https://github.com/byte-me-labs/jquery-docs/releases" target="_blank">CHM Download</a>';
sidebarHTML += '<a href="https://byte-me-labs.github.io/jquery-docs/" target="_blank">Online Docs</a>';
sidebarHTML += '</div></div>'; // close nav-categories
%>
<%- sidebarHTML %>
